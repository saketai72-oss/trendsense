# =============================================
# TrendSense — Environment Variables
# Copy file này thành .env rồi điền giá trị thật
# =============================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:port/database

# --- Supabase Storage (Presigned URL) ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_BUCKET=videos

# --- Upstash Redis (Queue + Rate Limiting) ---
REDIS_URL=rediss://default:xxxxxxxxxxxxxxxxxxxx@xxxx-xxxx-xxxx.upstash.io:6379

# --- Primary AI (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# --- Fallback AI (Groq Cloud) ---
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# --- Google Gemini AI (Multimodal Analysis) ---
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_WEBHOOK_URL=http://localhost:8000/api/analyze-gemini

# --- Modal (Serverless GPU) ---
# Chạy: modal token new → lấy ID và Secret
MODAL_TOKEN_ID=ak-xxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxx
MODAL_WEBHOOK_URL=https://your-workspace--trendsense-ai-analyze.modal.run

# --- Proxy (Tuỳ chọn cho Scraper) ---
# JSON array hoặc comma-separated string
PROXY_LIST=["http://user:pass@host:port"]
