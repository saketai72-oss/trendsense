# =============================================
# TrendSense — Environment Variables
# Copy file này thành .env rồi điền giá trị thật
# =============================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:port/database

# --- HuggingFace (Tùy chọn — nếu dùng model private) ---
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxx

# --- Groq Cloud AI (Bắt buộc cho production) ---
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# --- Modal (Serverless GPU) ---
# Chạy: modal token new → lấy ID và Secret
MODAL_TOKEN_ID=ak-xxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxx

# Chạy: modal deploy src/ai_core/modal_app.py → lấy URL webhook
MODAL_WEBHOOK_URL=https://your-workspace--trendsense-ai-analyze.modal.run
