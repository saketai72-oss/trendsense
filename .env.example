# =============================================
# TrendSense — Environment Variables
# Copy file này thành .env rồi điền giá trị thật
# =============================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:port/database

# --- Supabase Storage (Presigned URL) ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_BUCKET=videos

# --- Upstash Redis (Queue + Rate Limiting) ---
REDIS_URL=rediss://default:xxxxxxxxxxxxxxxxxxxx@xxxx-xxxx-xxxx.upstash.io:6379

# --- Primary AI (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# --- Fallback AI (Groq Cloud) ---
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# --- Google Gemini AI (Multimodal Analysis) ---
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_WEBHOOK_URL=http://localhost:8000/api/analyze-gemini

# --- Modal (Serverless GPU) ---
# Chạy: modal token new → lấy ID và Secret
MODAL_TOKEN_ID=ak-xxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxx
MODAL_WEBHOOK_URL=https://your-workspace--trendsense-ai-analyze.modal.run

# --- Proxy (Tuỳ chọn cho Scraper) ---
# JSON array hoặc comma-separated string
PROXY_LIST=["http://user:pass@host:port"]

# --- TikTok Hashtag Fetcher ---
# TikTokApi cần ms_token từ cookie TikTok (tự động lấy từ Selenium browser)
# Nếu cần set thủ công: Vào tiktok.com → F12 → Application → Cookies → copy ms_token
ms_token=

# --- Authentication (JWT) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-64-char-hex-secret-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Backend URL (for OAuth redirect defaults) ---
BACKEND_URL=http://localhost:8080

# --- OAuth: Google ---
# Get at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must point to FastAPI backend directly (not through Next.js proxy)
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# --- OAuth: GitHub ---
# Get at: https://github.com/settings/developers
GITHUB_CLIENT_ID=Ov23lixxxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must point to FastAPI backend directly (not through Next.js proxy)
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback
